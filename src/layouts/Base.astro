---
import '@/styles/global.css';
// KaTeX styles are required for `rehype-katex`-rendered formulae to display
// correctly. Imported globally so any page (CV, posts) can contain math.
import 'katex/dist/katex.min.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Lightbox from '@/components/Lightbox.astro';
import Shortcuts from '@/components/Shortcuts.astro';
import { t, type Lang } from '@/i18n/ui';
import { getProfileMeta } from '@/lib/content';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  // Per-page social-card image. Pass an Astro `image()` asset (preferred — its
  // bundled path is resolved against `Astro.site`) or a fully-qualified URL.
  // Falls back to `/og/default.png` (locale-aware), a 1200x630 card built at
  // build time by `src/pages/og/default.png.ts` so every page has a uniform
  // 1200x630 link-card preview regardless of whether it ships its own image.
  image?: ImageMetadata | string;
  // Optional structured-data hints for posts. When provided, a
  // BlogPosting node is added to the JSON-LD `@graph` alongside Person
  // and WebSite. Detail pages should pass the post's metadata; list
  // pages can omit this.
  article?: {
    title: string;
    description?: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
    wordCount?: number;
  };
  // Optional breadcrumb trail, leaf last. URLs may be relative; they are
  // resolved against `Astro.site` when emitted into the BreadcrumbList
  // JSON-LD. The trailing item (the current page) typically omits `url`.
  breadcrumbs?: Array<{ name: string; url?: string }>;
}
const { title, description, lang, image, article, breadcrumbs } = Astro.props;
const meta = await getProfileMeta(lang);

// Browser-tab title: "<page> | <site>". When the page title already equals
// the site name (the home page passes `meta.name`), skip the suffix to avoid
// "th | th". `<og:title>` keeps the bare page title — SNS previewers render
// the site name from their own domain/site_name handling.
// Empty siteName (profile.yaml leaves both name and siteHandle blank) also
// skips the suffix so the tab doesn't end with a stray "| ".
const siteName = meta.name;
const documentTitle = !siteName || title === siteName ? title : `${title} | ${siteName}`;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
// `/icon.png` is generated by scripts/build-icon.mjs from profile.yaml's
// `icon.url`. When that field is empty the PNG is intentionally absent,
// so we skip the favicon link rather than emit a 404-bound <link>.
const favicon = meta.icon ? '/icon.png' : undefined;
// Locale-aware default OG card. Generated at build time by
// `src/pages/og/default.png.ts` (and the /en/ mirror), 1200x630.
const defaultOgPath = lang === 'en' ? '/en/og/default.png' : '/og/default.png';
// Resolve against `Astro.url` (current request) rather than `Astro.site`
// (production host). In dev this yields http://localhost:4321/... so local
// OGP previewers can actually fetch the image; in prod builds the origin
// equals Astro.site, so the URL is production-correct as well.
//
// String inputs (e.g. the OG card route `/og/foo.png` returned by
// PostDetailPage) are also wrapped — OGP requires absolute URLs and Slack
// / Discord / Twitter Card validators reject relative paths. Already-
// absolute URLs (http(s)://) pass through `new URL()` unchanged.
const ogImage =
  typeof image === 'string'
    ? new URL(image, Astro.url).toString()
    : image
      ? new URL(image.src, Astro.url).toString()
      : new URL(defaultOgPath, Astro.url).toString();
// Width/height hints help SNS previewers reserve the card area before
// fetching bytes (faster perceived render, no layout shift). astro-og-canvas
// hardcodes 1200x630 for every generated card, so when the source is one of
// our `/og/...` routes (string input) or the locale default fallback, we
// know the dimensions exactly. For an Astro `image()` asset (heroImage),
// use the asset's own metadata.
const ogImageWidth = typeof image === 'object' && image !== null ? image.width : 1200;
const ogImageHeight = typeof image === 'object' && image !== null ? image.height : 630;
// All cards are now >= 1200x630, satisfying Twitter's `summary_large_image`
// minimum (300x157, 2:1 ratio). For a heroImage with non-2:1 aspect ratio,
// Twitter still accepts it but may letterbox.
const twitterCard = 'summary_large_image';
// Alt text for the OG image. Falls back to title — short, accurate, and
// what most SNS previewers surface to assistive tech. Twitter caps this
// at 420 chars; our titles + descriptions stay well under.
const ogImageAlt = description ?? title;
// `og:type` switches to `article` only when caller passes article metadata
// (i.e. post detail). Everything else stays `website`. The article
// branch then unlocks article:published_time / modified_time / tag.
const ogType = article ? 'article' : 'website';
const ogLocale = lang === 'ja' ? 'ja_JP' : 'en_US';
const ogLocaleAlternate = lang === 'ja' ? 'en_US' : 'ja_JP';

// Content-Security-Policy emitted via <meta http-equiv> because GitHub
// Pages does not let us set HTTP headers. Notes:
//   - `'unsafe-inline'` for script/style is required by the site's inline
//     blocks (JSON-LD, theme bootstrap, copy-code wiring, KaTeX inline
//     styles, Astro scoped style sheets). Tightening this would require
//     migrating to nonce-based CSP, which Astro 6 does not surface for
//     hand-written `<script is:inline>` blocks.
//   - `img-src https:` is intentionally broad because webmention author
//     photos arrive from arbitrary hosts via webmention.io. `data:` is
//     allowed for the small inline SVGs in markdown rendering.
//   - `frame-ancestors` is honored only when CSP is delivered as a real
//     HTTP header, not via <meta>. The docker/nginx.conf path therefore
//     also sets X-Frame-Options; on GitHub Pages the site is unprotected
//     from framing, which is acceptable for a public personal portfolio.
//   - Third-party origins listed correspond 1:1 to the configurable
//     integrations in profile.yaml (giscus, webmention, goatcounter) plus
//     the on-demand Twitter widget loaded by PostDetailPage.
const csp = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "form-action 'self'",
  "img-src 'self' data: https:",
  "font-src 'self'",
  "media-src 'self'",
  // giscus.app: client.js prepends `<link rel="stylesheet" href="https://giscus.app/default.css">`
  // to the document head; that sheet sets `.giscus, .giscus-frame { width: 100% }`. Without
  // it the iframe falls back to the HTML default 300px width.
  "style-src 'self' 'unsafe-inline' https://giscus.app",
  "script-src 'self' 'unsafe-inline' https://giscus.app https://platform.twitter.com https://*.twimg.com https://gc.zgo.at",
  "frame-src 'self' https://giscus.app https://platform.twitter.com",
  "connect-src 'self' https://webmention.io https://*.giscus.app https://api.github.com https://gc.zgo.at https://*.twitter.com",
].join('; ');

// JSON-LD structured data. Person describes the site owner, WebSite
// describes the site itself, and BlogPosting (when `article` is set)
// describes the current post. Search engines and social previewers
// merge these via the `@graph` aggregator.
const personLd = {
  '@type': 'Person',
  name: meta.name,
  url: Astro.site?.toString(),
  ...(meta.icon ? { image: meta.icon } : {}),
  ...(meta.affiliation ? { affiliation: meta.affiliation } : {}),
  ...(meta.links.length > 0 ? { sameAs: meta.links.map((l) => l.url) } : {}),
};
const websiteLd = {
  '@type': 'WebSite',
  name: meta.name,
  url: Astro.site?.toString(),
  inLanguage: lang === 'ja' ? 'ja-JP' : 'en-US',
};
const articleLd = article
  ? {
      '@type': 'BlogPosting',
      headline: article.title,
      ...(article.description ? { description: article.description } : {}),
      datePublished: article.pubDate.toISOString(),
      ...(article.updatedDate ? { dateModified: article.updatedDate.toISOString() } : {}),
      url: canonical,
      image: ogImage,
      inLanguage: lang === 'ja' ? 'ja-JP' : 'en-US',
      author: { '@type': 'Person', name: meta.name },
      // Publisher is the site itself (Person doubling as Publisher matches
      // Google's guidance for personal blogs — Organization is overkill).
      publisher: { '@type': 'Person', name: meta.name, url: Astro.site?.toString() },
      ...(article.wordCount ? { wordCount: article.wordCount } : {}),
      ...(article.tags && article.tags.length > 0 ? { keywords: article.tags.join(', ') } : {}),
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    }
  : null;
// BreadcrumbList shows search engines where this page sits in the site
// hierarchy. Emitted only when the caller supplied a trail.
const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        ...(b.url ? { item: new URL(b.url, Astro.site).toString() } : {}),
      })),
    }
  : null;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personLd,
    websiteLd,
    ...(articleLd ? [articleLd] : []),
    ...(breadcrumbLd ? [breadcrumbLd] : []),
  ],
};
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* CSP must precede any external-resource <link>/<script> so the
        browser applies it to the rest of <head>. See `csp` const above
        for directive rationale. */}
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <meta name="generator" content={Astro.generator} />
    <title>{documentTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    {favicon && <link rel="icon" type="image/png" href={favicon} />}

    {/* Preload the self-hosted Zen Maru Gothic TTFs so they arrive before
        first paint. Without this, every full-reload navigation paints first
        in the system fallback (Hiragino Maru Gothic ProN etc.) and then
        re-paints when the TTF arrives — producing a visible "navbar grows
        slightly then shrinks" flash, because the fallback metrics differ
        from Zen Maru Gothic by ~1px height / ~5px nav width. The TTFs are
        ~3.6 MB each but cached aggressively by the browser after the first
        visit; preload simply re-orders the request earlier in the load
        sequence so it lands before paint. `crossorigin` is required even
        for same-origin font preloads (font fetches are CORS-credentialed
        regardless of origin). */}
    <link rel="preload" href="/fonts/ZenMaruGothic-Regular.ttf" as="font" type="font/ttf" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/ZenMaruGothic-Bold.ttf" as="font" type="font/ttf" crossorigin="anonymous" />

    <!-- AI / ML opt-out signals. Honored by well-behaved crawlers; see also
         /robots.txt, /ai.txt, /.well-known/tdmrep.json. -->
    <meta name="robots" content="noai, noimageai" />
    <meta name="tdm-reservation" content="1" />
    <!-- Per-bot hints (low standardization but cheap to include). -->
    <meta name="GPTBot" content="noindex, nofollow" />
    <meta name="ClaudeBot" content="noindex, nofollow" />
    <meta name="Google-Extended" content="noindex, nofollow" />
    <meta name="PerplexityBot" content="noindex, nofollow" />
    <meta name="CCBot" content="noindex, nofollow" />

    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:type" content="image/png" />
    {description && <meta property="og:description" content={description} />}
    {article && (
      <>
        <meta property="article:published_time" content={article.pubDate.toISOString()} />
        {article.updatedDate && (
          <meta property="article:modified_time" content={article.updatedDate.toISOString()} />
        )}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {/* WebSub hub advertisement at the page level so subscribers that
        crawl the HTML head (rather than the feed) still find the hub. */}
    <link rel="hub" href="https://pubsubhubbub.appspot.com/" />
    <link rel="alternate" type="application/rss+xml" title={`${meta.siteHandle} posts (ja)`} href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${meta.siteHandle} posts (en)`} href="/en/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title={`${meta.siteHandle} posts (ja, Atom)`} href="/atom.xml" />
    <link rel="alternate" type="application/atom+xml" title={`${meta.siteHandle} posts (en, Atom)`} href="/en/atom.xml" />
    <link rel="alternate" type="application/feed+json" title={`${meta.siteHandle} posts (ja, JSON Feed)`} href="/feed.json" />
    <link rel="alternate" type="application/feed+json" title={`${meta.siteHandle} posts (en, JSON Feed)`} href="/en/feed.json" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="text/x-opml" title={`${meta.siteHandle} feeds (OPML)`} href="/feeds.opml" />

    <!-- Hreflang alternates so search engines understand the bilingual pair. -->
    {lang === 'ja' && (
      <link
        rel="alternate"
        hreflang="en"
        href={new URL(`/en${Astro.url.pathname === '/' ? '/' : Astro.url.pathname}`, Astro.site).toString()}
      />
    )}
    {lang === 'en' && (
      <link
        rel="alternate"
        hreflang="ja"
        href={new URL(Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/', Astro.site).toString()}
      />
    )}

    {/* `</script>` inside JSON would break out of the inline script block;
        replace `<` with its JSON unicode escape so any future title or
        description containing the substring stays inside the JSON value. */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')}
    />

    {/* Webmention discovery links — register at https://webmention.io to obtain endpoints. */}
    {meta.integrations.webmention && (
      <>
        <link rel="webmention" href={meta.integrations.webmention.endpoint} />
        {meta.integrations.webmention.pingback && (
          <link rel="pingback" href={meta.integrations.webmention.pingback} />
        )}
      </>
    )}

    {/* Privacy-respecting analytics (GoatCounter). No cookies, no PII.
        Guard on the inner endpoint, not the outer object — schema can
        leave `analytics: {}` with an empty endpoint, which would
        otherwise still inject the script and POST to `/count`. */}
    {meta.integrations.analytics?.goatcounterEndpoint && (
      <script
        is:inline
        async
        data-goatcounter={`${meta.integrations.analytics.goatcounterEndpoint}/count`}
        src="https://gc.zgo.at/count.js"
      />
    )}

    {/* Google AdSense site verification. The presence of `clientId` here
        is enough for AdSense to verify ownership during the application
        review; the actual ad-loader script is intentionally NOT injected
        until the application is approved (and Lighthouse impact is
        measured). See profile.yaml `adsense.clientId`. */}
    {meta.integrations.adsense && (
      <meta name="google-adsense-account" content={meta.integrations.adsense.clientId} />
    )}

    <!-- Pre-paint theme override. The <html> element ships with
         data-theme="dark" as a sensible fallback. We then prefer (in order):
         (1) the user's persisted choice in localStorage, (2) the OS-level
         `prefers-color-scheme` setting, and (3) the dark default. Running
         here (before body paint) avoids the flash-of-wrong-theme. -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.dataset.theme = saved;
            return;
          }
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.dataset.theme = 'light';
          }
        } catch {
          // localStorage / matchMedia unavailable — keep the markup default.
        }
      })();
    </script>

  </head>
  <body>
    <a class="skip-link" href="#main-content">{t(lang, 'a11y.skipToMain')}</a>
    <Header lang={lang} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <Lightbox />
    <Shortcuts lang={lang} />

    <script is:inline data-astro-rerun define:vars={{ lCopy: t(lang, 'code.copy'), lCopied: t(lang, 'code.copied') }}>
      // Inject a copy-to-clipboard button into every fenced code block.
      // Skip `pre.mermaid` blocks — those get replaced by SVG by the
      // Mermaid renderer and would have nothing meaningful to copy.
      const pres = document.querySelectorAll('main pre:not(.mermaid)');
      pres.forEach((pre) => {
        const code = pre.querySelector('code');
        if (!code || pre.querySelector('.copy-code')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-code';
        btn.textContent = lCopy;
        btn.setAttribute('aria-label', lCopy);
        btn.addEventListener('click', async () => {
          const text = code.innerText;
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          btn.textContent = lCopied;
          btn.classList.add('is-copied');
          window.setTimeout(() => {
            btn.textContent = lCopy;
            btn.classList.remove('is-copied');
          }, 1600);
        });
        pre.appendChild(btn);
      });
    </script>

    <style is:global>
      /* Copy button stays in the top-right of every `<pre>`. The parent
         must be `position: relative`, which we set inline in the script
         path? No — set it here so SSR-rendered `<pre>` is already
         positioned before JS attaches. */
      main pre:not(.mermaid) { position: relative; }
      .copy-code {
        position: absolute;
        top: 0.4rem;
        right: 0.4rem;
        padding: 0.15rem 0.55rem;
        font-size: 0.75rem;
        line-height: 1.4;
        color: var(--color-muted);
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        cursor: pointer;
        opacity: 0;
        transition: opacity 160ms ease, color 160ms ease, border-color 160ms ease;
      }
      main pre:hover .copy-code,
      main pre:focus-within .copy-code,
      .copy-code:focus-visible { opacity: 1; }
      .copy-code:hover,
      .copy-code:focus-visible {
        color: var(--color-accent);
        border-color: var(--color-accent);
      }
      .copy-code.is-copied {
        opacity: 1;
        color: var(--color-accent-hover);
        border-color: var(--color-accent-hover);
      }
    </style>
  </body>
</html>
