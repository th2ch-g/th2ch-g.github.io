---
import { t, type Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const label = t(lang, 'theme.toggle');
---
<button type="button" class="theme-toggle" data-theme-toggle aria-label={label} title={label}>
  <span class="icon sun" aria-hidden="true">☀</span>
  <span class="icon moon" aria-hidden="true">☾</span>
</button>

<script>
  import { onReady } from '@/lib/dom-ready';

  // Pre-paint script in Base.astro already set html[data-theme]. This script
  // wires the toggle button(s) and persists the choice in localStorage.
  const STORAGE_KEY = 'theme';

  function apply(theme: 'light' | 'dark') {
    document.documentElement.dataset.theme = theme;
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      // localStorage may be blocked (private mode, strict cookie settings); ignore.
    }
  }

  // Wire on DOMContentLoaded — `<ClientRouter />` was removed, so the
  // `astro:page-load` event is never dispatched. Astro module scripts
  // are defer-loaded so `readyState` is usually already past 'loading',
  // but we register both paths for safety.
  function wireThemeToggles() {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        apply(current === 'dark' ? 'light' : 'dark');
      });
    });
  }
  onReady(wireThemeToggles);
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-fg);
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
  }
  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .icon {
    display: none;
  }
  /* Show the icon representing the *target* theme (what clicking will switch to). */
  :global(:root[data-theme="light"]) .theme-toggle .moon,
  :global(:root:not([data-theme])) .theme-toggle .moon {
    display: inline;
  }
  :global(:root[data-theme="dark"]) .theme-toggle .sun {
    display: inline;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .theme-toggle .moon {
      display: none;
    }
    :global(:root:not([data-theme])) .theme-toggle .sun {
      display: inline;
    }
  }
</style>
