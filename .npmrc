# astro-og-canvas (build-time OG card rendering) still declares a peer range
# of `astro@^5 || ^6` even though it imports no Astro runtime API — its only
# Astro reference is a type-only import of APIRoute/GetStaticPaths, stable
# across the 6→7 bump. Allow the install (and `npm ci` in CI) to proceed past
# that stale peer. Remove once astro-og-canvas ships an Astro 7 peer range.
legacy-peer-deps=true
