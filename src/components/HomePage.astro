---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '@/layouts/Base.astro';
import PostEntry from './PostEntry.astro';
import { t, type Lang } from '@/i18n/ui';
import {
  getProfileMeta,
  getPublishedByLang,
  sortByDateDesc,
} from '@/lib/content';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;

const meta = await getProfileMeta(lang);
const recentPosts = sortByDateDesc(
  await getPublishedByLang('posts', lang),
  'pubDate',
).slice(0, 3);

// Gallery images are loose files (no .md = no date) and we want a fresh
// rotation on each deploy rather than a static "latest 3". Shuffle the
// whole set with Fisher–Yates at build time, then take 4 — re-rolls per
// build because Math.random() runs at build time, stays decisive within
// a single deploy.
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/gallery/*.{jpg,jpeg,png,webp,avif,svg}',
  { eager: true },
);
const photoEntries = Object.entries(photoModules);
for (let i = photoEntries.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [photoEntries[i], photoEntries[j]] = [photoEntries[j], photoEntries[i]];
}
const recentPhotos = photoEntries.slice(0, 4).map(([, mod]) => mod.default);
const galleryHref = getRelativeLocaleUrl(lang, '/photos');
---
{/* Home page is titled with the site brand (meta.name), not "Home": this
    collapses `documentTitle` to just the brand and makes og:title /
    twitter:title the brand instead of a generic "Home" on social shares.
    No description is passed: Base falls back to the bio. */}
<Base lang={lang} title={meta.name}>
  <section class="hero">
    <div class="hero-head">
      {meta.icon && (
        <div class="avatar-wrap">
          <img class="avatar" src="/icon.png" alt={meta.name} width="72" height="72" loading="eager" />
          {meta.iconComment && (
            <span class="avatar-tip" role="tooltip">{meta.iconComment}</span>
          )}
        </div>
      )}
      <h1>{meta.name}</h1>
    </div>
    {meta.bio && <p class="bio">{meta.bio}</p>}
    {meta.links.length > 0 && (
      <ul class="bare links">
        {meta.links.map((link) => (
          <li class="link-item">
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  {recentPosts.length > 0 && (
    <section>
      <h2>{t(lang, 'home.recent.posts')}</h2>
      {recentPosts.map((post) => <PostEntry post={post} lang={lang} />)}
      <p class="see-all">
        <a href={getRelativeLocaleUrl(lang, '/posts')}>
          {t(lang, 'home.see.all')}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </p>
    </section>
  )}

  {recentPhotos.length > 0 && (
    <section>
      <h2>{t(lang, 'home.recent.photos')}</h2>
      <div class="photo-grid">
        {recentPhotos.map((photo, i) => (
          <button
            type="button"
            class="photo-thumb"
            aria-label={`${t(lang, 'nav.photos')} ${i + 1}`}
          >
            <Image src={photo} alt="" loading="lazy" />
          </button>
        ))}
      </div>
      <p class="see-all">
        <a href={galleryHref}>
          {t(lang, 'home.see.all')}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </p>
    </section>
  )}
</Base>

<script>
  import { wirePhotoLightbox } from '@/lib/lightbox';
  wirePhotoLightbox('.photo-thumb');
</script>

<style>
  /* Centred profile card. Stacking the hero as a flex column lets each
     row (avatar+name, bio, links) auto-shrink to its
     content width and centre as a unit, instead of left-aligning to
     main's padding edge. `text-align: center` propagates so multi-line
     paragraphs (e.g. a long bio that wraps) stay centred too. */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 2rem;
  }
  /* Avatar + name share a single horizontal row. The wrapper absorbs the
     vertical spacing that <h1> would otherwise contribute (h1's default
     1.5em/0.5em margins from layout.css would inflate the flex row), so
     the avatar sits flush against the name baseline. */
  .hero-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 1.5em 0 0.5em;
  }
  .hero-head > h1 {
    margin: 0;
  }
  /* Avatar wrapper: `width: max-content` hugs the 72px image so it sits as a
     tight unit in the centred hero row. `position: relative` anchors the
     comment bubble below the avatar. */
  .avatar-wrap {
    position: relative;
    display: block;
    width: max-content;
  }
  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
    background: var(--color-card);
    display: block;
    transition:
      border-color 200ms ease,
      box-shadow 260ms ease;
  }
  .avatar:hover {
    border-color: var(--color-accent);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }
  /* Comment bubble shown on avatar hover. The avatar <img> isn't focusable,
     so this is hover-only, matching the original behaviour. */
  .avatar-tip {
    position: absolute;
    top: calc(100% + 0.55rem);
    left: 50%;
    transform: translate(-50%, -4px);
    background: var(--color-card);
    color: var(--color-fg);
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    padding: 0.35rem 0.65rem;
    font-size: 0.85rem;
    line-height: 1.35;
    max-width: 14rem;
    width: max-content;
    text-align: center;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease;
    z-index: 5;
  }
  /* Speech-bubble arrow. Border arrow sits one pixel above the fill arrow
     so the 1px card border is preserved along the bubble's top edge. */
  .avatar-tip::before,
  .avatar-tip::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border: 6px solid transparent;
  }
  .avatar-tip::before {
    bottom: 100%;
    border-bottom-color: var(--color-border);
  }
  .avatar-tip::after {
    bottom: calc(100% - 1px);
    border-bottom-color: var(--color-card);
  }
  .avatar-wrap:hover .avatar-tip {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .avatar-tip { transition: opacity 0ms; }
  }
  /* Mobile: cap the bubble width to the viewport minus main's side padding so
     a long comment wraps instead of overflowing. */
  @media (max-width: 720px) {
    .avatar-tip { max-width: calc(100vw - 2rem); }
  }
  .bio { font-size: 1.1rem; color: var(--color-muted); margin: 0.25rem 0 0.5rem; }
  /* SNS links as a centred, wrapping row of plain-text links separated by
     literal "|" dividers (no trailing bar). Replaces the former icon pills. */
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0.75rem 0;
    font-size: 0.95rem;
  }
  .links a {
    color: var(--color-fg);
    transition: color 160ms ease;
  }
  .links a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  /* Pipe divider after every item but the last. The left 0.5rem margin pairs
     with the flex gap on the right so the bar is evenly spaced on both sides. */
  .link-item:not(:last-child)::after {
    content: '|';
    margin-left: 0.5rem;
    color: var(--color-border);
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .photo-thumb {
    /* `<button>` reset so it visually behaves like the previous `<a>`
       wrapper. width:100% lets the grid track size drive the cell width;
       padding/border/background reset clears the UA defaults. */
    width: 100%;
    padding: 0;
    border: 0;
    background: var(--color-border);
    cursor: zoom-in;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 14px;
    transition: transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 260ms ease;
  }
  .photo-thumb:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }
  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .photo-thumb:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    text-decoration: none;
  }
  /* Inner-img zoom on hover lives in src/styles/global.css per project
     contract (see CLAUDE.md "CSS gotchas"). The transition declaration
     above stays scoped because it targets the element directly. */
  @media (prefers-reduced-motion: reduce) {
    .photo-thumb,
    .photo-thumb img { transition: none; }
  }

  /* "See all" pill link at the bottom of each section. Pill-shaped to
     echo the social-icon row in the hero; sliding arrow on hover gives
     the affordance that this leads somewhere without yelling about it. */
  .see-all {
    margin-top: 0.85rem;
    text-align: right;
  }
  .see-all a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-fg);
    font-size: 0.9rem;
    line-height: 1;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 200ms ease,
      transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .see-all a:hover,
  .see-all a:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-card);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12);
  }
  .see-all a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  /* Split the arrow into its own span so only it slides on hover —
     keeping the label still avoids the "whole pill jitters" feel. */
  .see-all .arrow {
    display: inline-block;
    transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .see-all a:hover .arrow,
  .see-all a:focus-visible .arrow {
    transform: translateX(0.3rem);
  }
  @media (prefers-reduced-motion: reduce) {
    .see-all a,
    .see-all .arrow { transition: none; }
    .see-all a:hover,
    .see-all a:focus-visible,
    .see-all a:hover .arrow,
    .see-all a:focus-visible .arrow { transform: none; }
  }
</style>
