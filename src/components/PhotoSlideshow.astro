---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  // Slide change interval in milliseconds.
  intervalMs?: number;
}

const { images, intervalMs = 5000 } = Astro.props;
---
{images.length > 0 && (
  <div
    class="photo-slideshow"
    data-interval={intervalMs}
    aria-roledescription="carousel"
    tabindex="-1"
  >
    <div class="slides">
      {images.map((img, i) => (
        <div class:list={['slide', { active: i === 0 }]} aria-hidden={i === 0 ? 'false' : 'true'}>
          <Image src={img} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
    <div class="controls">
      {images.length > 1 && (
        <div class="speed" role="group" aria-label="Slideshow speed">
          <button type="button" class="speed-btn" data-speed="3000" aria-label="Fast (3s)">3s</button>
          <button type="button" class="speed-btn active" data-speed="5000" aria-label="Normal (5s)">5s</button>
          <button type="button" class="speed-btn" data-speed="8000" aria-label="Slow (8s)">8s</button>
        </div>
      )}
      <button type="button" class="fullscreen-btn" aria-label="Toggle fullscreen">
        <svg class="enter" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            d="M4 9V4h5M15 4h5v5M20 15v5h-5M9 20H4v-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <svg class="exit" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            d="M9 4v5H4M15 4v5h5M15 20v-5h5M9 20v-5H4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    </div>
    {images.length > 1 && (
      <>
        <button type="button" class="nav prev" data-dir="-1" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path
              d="M15 6l-6 6 6 6"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
        <button type="button" class="nav next" data-dir="1" aria-label="Next">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path
              d="M9 6l6 6-6 6"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
        <div class="progress">
          <div
            class="progress-bar"
            role="progressbar"
            aria-valuemin="1"
            aria-valuemax={images.length}
            aria-valuenow="1"
            aria-label="Slide position"
          >
            <div class="progress-fill" style={`width: ${100 / images.length}%`} />
          </div>
          <div class="progress-count" aria-live="polite">
            <span class="progress-current">1</span>
            <span class="progress-sep"> / </span>
            <span class="progress-total">{images.length}</span>
          </div>
        </div>
      </>
    )}
  </div>
)}

<style>
  .photo-slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-border);
    margin-bottom: 1.5rem;
  }
  /* Root is programmatically focused (tabindex="-1") so arrow keys work the
     instant fullscreen begins; suppress the UA focus ring on the container
     itself since inner buttons still draw their own :focus-visible rings. */
  .photo-slideshow:focus { outline: none; }
  .slides {
    position: absolute;
    inset: 0;
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms ease;
    pointer-events: none;
  }
  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }
  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .progress {
    position: absolute;
    bottom: 0.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.55rem;
    z-index: 1;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none;
  }
  .progress-bar {
    position: relative;
    width: 120px;
    height: 3px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    background: #fff;
    border-radius: 2px;
    transition: width 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .progress-count {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    white-space: nowrap;
    line-height: 1;
  }
  .progress-sep { opacity: 0.6; padding: 0 0.05rem; }
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    z-index: 2;
    transition: background 150ms ease, transform 150ms ease;
  }
  .nav:hover { background: rgba(0, 0, 0, 0.7); }
  .nav:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .nav.prev { left: 0.5rem; }
  .nav.next { right: 0.5rem; }
  .nav:active { transform: translateY(-50%) scale(0.92); }
  .controls {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    gap: 0.4rem;
    z-index: 3;
  }
  .speed {
    display: inline-flex;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 999px;
    padding: 2px;
  }
  .speed-btn {
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.75);
    font: inherit;
    font-size: 0.75rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
  }
  .speed-btn:hover { color: #fff; }
  .speed-btn.active {
    background: #fff;
    color: #111;
    font-weight: 600;
  }
  .speed-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .fullscreen-btn {
    width: 32px;
    height: 32px;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 150ms ease;
  }
  .fullscreen-btn:hover { background: rgba(0, 0, 0, 0.7); }
  .fullscreen-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .fullscreen-btn .exit { display: none; }
  .photo-slideshow:fullscreen {
    width: 100vw;
    height: 100vh;
    aspect-ratio: auto;
    border-radius: 0;
    background: #000;
    margin: 0;
  }
  .photo-slideshow:fullscreen .slide img { object-fit: contain; }
  .photo-slideshow:fullscreen .fullscreen-btn .enter { display: none; }
  .photo-slideshow:fullscreen .fullscreen-btn .exit { display: block; }
  .photo-slideshow:fullscreen .nav { width: 48px; height: 48px; }
  .photo-slideshow:fullscreen .progress-bar { width: 200px; height: 4px; }
  .photo-slideshow:fullscreen .progress-count { font-size: 0.85rem; }
  .photo-slideshow:fullscreen .progress { bottom: 1rem; }
  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
  }
</style>

<script>
  import { wireSlideshows } from '@/lib/slideshow-init';
  wireSlideshows();
</script>
